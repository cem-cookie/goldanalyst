# Streamlit Secrets Template
# Copy this file to .streamlit/secrets.toml and fill in your API keys
# The secrets.toml file is automatically .gitignored by Streamlit

# Deployer API key (used as fallback when user doesn't provide their own key)
# This is your API key that will be used for users who don't enter their own key
openai_api_key = "your-openai-api-key-here"

# Optional: DeepSeek API key for fallback
# deepseek_api_key = "your-deepseek-api-key-here"
