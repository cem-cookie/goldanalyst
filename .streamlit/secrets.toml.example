# Streamlit Secrets Template
# Copy this file to .streamlit/secrets.toml and fill in your API keys
# The secrets.toml file is automatically .gitignored by Streamlit
#
# Usage:
#   1. Copy this file to .streamlit/secrets.toml
#   2. Replace placeholder values with your actual API keys
#   3. The dashboard will use these as fallback when users don't provide their own key

# OpenAI API key (primary)
openai_api_key = "sk-your-openai-key-here"

# Optional: DeepSeek API key for fallback chain
# deepseek_api_key = "your-deepseek-api-key-here"

# Optional: Anthropic API key (for Claude models)
# anthropic_api_key = "your-anthropic-key-here"
